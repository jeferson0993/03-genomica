// ─── Test Profile (chr22) ───
// Para validação rápida com cromossomo 22

params {
    ref_fasta = "/ref/grch22/GRCh38.fa"  // ou chr22-only reference
    ref_bwa_index = "/ref/grch22/bwa/hg38"
    ref_dict = "/ref/grch22/GRCh38.dict"
    ref_dbsnp = "/ref/grch22/known-sites/dbsnp_151.vcf.gz"
    ref_known_indels = "/ref/grch22/known-sites/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
}

process {
    withName: 'GATK_HAPLOTYPECALLER' { cpus = 2; memory = 4.GB }
    withName: 'BWA_ALIGN' { cpus = 2; memory = 4.GB }
}

executor {
    queueSize = 2
}
