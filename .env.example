# Database
DATABASE_URL=postgresql+asyncpg://platform:platform@postgres:5432/platform

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed
MINIO_BUCKET_CURATED=curated
MINIO_SECURE=false

# Genomics
GENOMICS_REF_DIR=/ref
GENOMICS_WORKSPACE=/workspace
GENOMICS_PIPELINE_DIR=/pipeline
GENOMICS_WORKER_CONTAINER=03-genomica-worker-1
GENOMICS_DEFAULT_PROFILE=docker

# Rate limiting
MAX_CONCURRENT_RUNS=2

# Data Lake
DATALAKE_API_URL=http://api-data-lake:8000

# Domain (CORS)
DOMAIN=localhost

# Logging
LOG_LEVEL=INFO

# PostgreSQL (compose-level)
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform

# MinIO root (compose-level)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
